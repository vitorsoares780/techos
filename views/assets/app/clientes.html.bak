<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clientes — TechOS</title>
  <meta name="description" content="Painel da assistência técnica no TechOS.">

  <link rel="preconnect" href="https://fonts.googleapis.com">

  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap">

  <link rel="stylesheet" href="../_common/styles/base.css">

  <link rel="stylesheet" href="styles/app.css">
</head>

<body class="app">

  <header class="app-topbar">

    <section style="display:flex;align-items:center;gap:0.75rem">

      <button class="sidebar-toggle" type="button" aria-label="Abrir menu lateral" data-sidebar-toggle>
        <span></span><span></span><span></span>
      </button>

      <a class="brand" href="dashboard.html">
        <img src="../_common/images/logo.png" class="logo">
        TechOS
      </a>

    </section>

    <label class="app-search" aria-label="Buscar">
      <input type="search" placeholder="Buscar OS, cliente ou equipamento…" data-global-search>
    </label>

    <section class="app-topbar-actions">

      <button class="icon-btn" type="button" aria-label="Notificações" data-badge="3">🔔</button>

      <button class="user-chip" type="button" aria-label="Conta" data-user-menu>

        <span class="avatar" aria-hidden="true">MC</span>
        <span>Marina</span>

      </button>

    </section>

  </header>

  <section class="app-shell">

    <aside class="app-sidebar" data-sidebar>

      <section class="sidebar-section">

        <h4>Operação</h4>
        <ul>
          <li><a class="sidebar-link" href="dashboard.html"><span class="ico" aria-hidden="true">📊</span>Visão
              geral</a></li>
          <li><a class="sidebar-link" href="ordens.html"><span class="ico" aria-hidden="true">🧾</span>Ordens de
              serviço</a></li>
          <li><a class="sidebar-link" href="ordem-nova.html"><span class="ico" aria-hidden="true">➕</span>Nova OS</a>
          </li>
          <li><a class="sidebar-link" aria-current="page" href="clientes.html"><span class="ico"
                aria-hidden="true">👥</span>Clientes</a></li>
          <li><a class="sidebar-link" href="equipamentos.html"><span class="ico"
                aria-hidden="true">🛠️</span>Equipamentos</a></li>
          <li><a class="sidebar-link" href="equipe.html"><span class="ico" aria-hidden="true">👷</span>Equipe</a></li>
                aria-hidden="true">📈</span>Relatórios</a></li>
        </ul>

      </section>

      <section class="sidebar-section">
        <h4>Conta</h4>
        <ul>
          <li><a class="sidebar-link" href="perfil.html"><span class="ico" aria-hidden="true">👤</span>Perfil</a></li>
          <li><a class="sidebar-link" href="configuracoes.html"><span class="ico"
                aria-hidden="true">⚙️</span>Configurações</a></li>
          <li><a class="sidebar-link" href="../public/login.html"><span class="ico" aria-hidden="true">🚪</span>Sair</a>
          </li>
        </ul>
      </section>

    </aside>

    <main class="app-main">

      <section class="page-head">

        <section>
          <h1>Clientes</h1>
          <p>Base de clientes da assistência.</p>
        </section>

        <section class="page-actions"><button class="btn btn-primary" type="button">+ Novo cliente</button></section>

      </section>

      <article class="panel">

        <form class="toolbar" onsubmit="return false">
          <input class="grow" type="search" placeholder="Buscar por nome, CPF/CNPJ ou e-mail…">

          <select aria-label="Tipo">
            <option value="">Todos</option>
            <option>Pessoa física</option>
            <option>Pessoa jurídica</option>
          </select>

        </form>

        <section class="table-wrap">

          <table class="data">
            <thead>
              <tr>
                <th>Nome</th>
                <th>Tipo</th>
                <th>Contato</th>
                <th>OS no histórico</th>
                <th></th>
              </tr>
            </thead>

            <tbody>
              <tr>
                <td>Carla Andrade</td>
                <td>PF</td>
                <td>carla@email.com</td>
                <td>8</td>
                <td>14/05/2026</td>
                <td><span class="row-actions"><a href="#">Ver</a></span></td>
              </tr>
              <tr>
                <td>Mercado União Ltda</td>
                <td>PJ</td>
                <td>compras@uniao.com.br</td>
                <td>21</td>
                <td>14/05/2026</td>
                <td><span class="row-actions"><a href="#">Ver</a></span></td>
              </tr>
              <tr>
                <td>João Vieira</td>
                <td>PF</td>
                <td>joaov@email.com</td>
                <td>3</td>
                <td>14/05/2026</td>
                <td><span class="row-actions"><a href="#">Ver</a></span></td>
              </tr>
              <tr>
                <td>Studio Foco</td>
                <td>PJ</td>
                <td>contato@studiofoco.com</td>
                <td>12</td>
                <td>13/05/2026</td>
                <td><span class="row-actions"><a href="#">Ver</a></span></td>
              </tr>
              <tr>
                <td>Ana Beatriz</td>
                <td>PF</td>
                <td>anab@email.com</td>
                <td>5</td>
                <td>12/05/2026</td>
                <td><span class="row-actions"><a href="#">Ver</a></span></td>
              </tr>
              <tr>
                <td>Loja Bicicletas Sul</td>
                <td>PJ</td>
                <td>contato@bikesul.com</td>
                <td>9</td>
                <td>12/05/2026</td>
                <td><span class="row-actions"><a href="#">Ver</a></span></td>
              </tr>
            </tbody>

          </table>

        </section>

      </article>

    </main>

  </section>

  <script src="scripts/app.js"></script>
</body>

</html>